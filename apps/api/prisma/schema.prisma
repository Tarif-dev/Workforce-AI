generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String             @id @default(uuid())

  name      String
  slug      String             @unique

  timezone  String             @default("Asia/Kolkata")

  status    OrganizationStatus @default(ACTIVE)

  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  users     User[]
  projects  Project[]
}

model Role {
  id          String   @id @default(uuid())

  name        RoleType @unique

  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

model User {
  id             String        @id @default(uuid())

  clerkUserId    String        @unique

  organizationId String?
  roleId         String?

  name           String
  email          String

  firstName      String?
  lastName       String?

  imageUrl       String?

  phoneNumber    String?

  status         UserStatus    @default(ACTIVE)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization? @relation(fields: [organizationId], references: [id])

  role           Role? @relation(fields: [roleId], references: [id])

  timesheets     Timesheet[]

  leaveRequests  LeaveRequest[]
  
  attendanceRecords AttendanceRecord[]

  conversationContext ConversationContext?

  @@unique([organizationId, email])
}

model Project {
  id             String        @id @default(uuid())

  organizationId String

  code           String
  name           String

  description    String?

  status         ProjectStatus @default(ACTIVE)

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id])

  timesheetEntries TimesheetEntry[]

  @@unique([organizationId, code])

  @@index([organizationId])
}

model Timesheet {
  id         String          @id @default(uuid())

  userId     String

  workDate   DateTime

  totalHours Float           @default(0)

  status     TimesheetStatus @default(SUBMITTED)

  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user        User @relation(fields: [userId], references: [id])

  entries     TimesheetEntry[]

  @@unique([userId, workDate])

  @@index([userId])

  @@index([workDate])
}

model TimesheetEntry {
  id          String   @id @default(uuid())

  timesheetId String

  projectId   String?

  description String?

  hours       Float

  createdAt   DateTime @default(now())

  timesheet   Timesheet @relation(fields: [timesheetId], references: [id])

  project     Project? @relation(fields: [projectId], references: [id])

  @@index([timesheetId])

  @@index([projectId])
}

model LeaveRequest {
  id         String      @id @default(uuid())

  userId     String

  leaveType  LeaveType

  startDate  DateTime

  endDate    DateTime

  reason     String?

  status     LeaveStatus @default(PENDING)

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user        User @relation(fields: [userId], references: [id])

  @@index([userId])

  @@index([startDate])

  @@index([endDate])
}

model AttendanceRecord {
  id         String   @id @default(uuid())
  userId     String
  date       DateTime // Normalized to midnight UTC

  status     AttendanceStatus @default(PRESENT)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  punches    AttendancePunch[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model AttendancePunch {
  id         String   @id @default(uuid())
  recordId   String
  type       PunchType // IN, OUT

  timestamp  DateTime @default(now()) // Stored as UTC

  record     AttendanceRecord @relation(fields: [recordId], references: [id])

  @@index([recordId])
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model ConversationContext {
  id              String   @id @default(uuid())

  userId          String   @unique

  intent          String

  extractedData   Json

  pendingQuestion String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
}

enum RoleType {
  EMPLOYEE
  MANAGER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum LeaveType {
  SICK
  CASUAL
  EARNED
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  WFH
  ABSENT
}

enum PunchType {
  IN
  OUT
}

model AuditLog {
  id             String   @id @default(uuid())

  userId         String

  message        String

  intent         String?

  contextUsed    Boolean  @default(false)

  extractedData  Json?

  validationData Json?

  toolName       String?

  toolResult     Json?

  success        Boolean

  error          String?

  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}